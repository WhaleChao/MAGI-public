{
  "_schema_version": "1.0.0",
  "_description": "MAGI model role registry. Maps logical roles to concrete model identifiers.",
  "defaults": {
    "text_primary": "gemma-4-26b-a4b-it-4bit",
    "vision": "GLM-OCR-bf16",
    "embedding": "modernbert-embed-4bit",
    "ocr": "GLM-OCR-bf16"
  },
  "roles": {
    "text_primary": {
      "description": "Primary text generation model",
      "model": "gemma-4-26b-a4b-it-4bit",
      "env_override": "MAGI_TEXT_PRIMARY_MODEL",
      "env_aliases": ["MAGI_MAIN_MODEL", "CASPER_LOCAL_MODEL"]
    },
    "text_review": {
      "description": "Traditional Chinese output review",
      "model": null,
      "fallback_role": "text_primary",
      "env_override": "MAGI_TW_REVIEW_MODEL"
    },
    "general": {
      "description": "General purpose LLM tasks",
      "model": null,
      "fallback_role": "text_primary",
      "env_override": "MAGI_OMLX_GENERAL_MODEL"
    },
    "summary": {
      "description": "Text summarization",
      "model": null,
      "fallback_role": "text_primary",
      "env_override": "MAGI_OMLX_SUMMARY_MODEL"
    },
    "code": {
      "description": "Code analysis and generation",
      "model": null,
      "fallback_role": "text_primary",
      "env_override": "MAGI_OMLX_CODE_MODEL"
    },
    "vision": {
      "description": "Vision/multimodal tasks (GLM-OCR on port 8082)",
      "model": "GLM-OCR-bf16",
      "env_override": "MAGI_OMLX_VISION_MODEL"
    },
    "ocr": {
      "description": "OCR document extraction (GLM-OCR on port 8082)",
      "model": "GLM-OCR-bf16",
      "env_override": "MAGI_OMLX_OCR_MODEL"
    },
    "embedding": {
      "description": "Text embedding",
      "model": "modernbert-embed-4bit",
      "env_override": "MAGI_OMLX_EMBED_MODEL"
    }
  },
  "aliases": {
    "_description": "Legacy model name aliases that resolve to text_primary",
    "names": [
      "", "taide", "taide-12b", "taide-12b-chat-mlx-4bit",
      "gemma-4", "gemma4", "gemma-4-26b", "gemma-4-26b-a4b",
      "gemma-4-e2b-it-local-bf16", "gemma-4-26b-a4b-it-4bit",
      "gemma-4-e4b-it-4bit", "gemma4:26b",
      "gemma4:26b-a4b-it-q4_K_M", "gemma-4-e4b-it-bf16"
    ]
  }
}
