# MAGI v2 Environment Variables
# Copy this to .env and fill in your values

# ── Database ───────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_USER=casper_service
DB_PASSWORD=<your-db-password>
MAGI_LOCAL_DB_PORT=3306
OSC_DB_HOST=<remote-db-ip>
OSC_DB_PORT=3306
OSC_DB_USER=casper_service
OSC_DB_PASSWORD=<your-db-password>
OSC_DB_NAME=law_firm_data

# ── Telegram ───────────────────────────────────────────────
OPENCLAW_TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_WEBHOOK_SECRET=<your-webhook-secret>
MAGI_ADMIN_TELEGRAM_IDS=<your-telegram-user-id>

# ── Discord ────────────────────────────────────────────────
DISCORD_BOT_TOKEN=<your-discord-bot-token>

# ── LINE ───────────────────────────────────────────────────
MAGI_LINE_CHANNEL_ACCESS_TOKEN=<your-line-access-token>
MAGI_LINE_CHANNEL_SECRET=<your-line-channel-secret>

# ── oMLX (Local LLM) ──────────────────────────────────────
MAGI_OMLX_ENABLED=1
OMLX_BASE_URL=http://127.0.0.1:8080/v1
OMLX_API_KEY=omlx-local
MAGI_DEFAULT_MODEL=taide-12b

# ── LLM Direct + Agent Features ───────────────────────────
MAGI_LLM_DIRECT=1
MAGI_REACT_ENABLED=1
MAGI_FEEDBACK_LEARNING=1
MAGI_CONTINUOUS_LEARN=1
# ANTHROPIC_API_KEY=sk-ant-...

# ── Flask ──────────────────────────────────────────────────
FLASK_SECRET_KEY=<random-hex-string>
MAGI_API_KEY=<random-hex-string>

# ── Paths ──────────────────────────────────────────────────
MAGI_ROOT_DIR=/path/to/MAGI_v2
MAGI_SKILL_PYTHON=/path/to/MAGI_v2/venv/bin/python3

# ── Paperclip 檔案分享 ──────────────────────────────────────
# 務必使用獨立分享入口，不要填 MAGI/Paperclip 主控台網址。
# 例：https://paperclip-share.example.com
MAGI_OSC_FILE_SHARE_PUBLIC_BASE_URL=
MAGI_OSC_FILE_SHARE_TTL_SEC=604800
MAGI_OSC_FILE_SHARE_MAX_TTL_SEC=2592000

# ── T3 LAF 進度回報確認碼 ────────────────────────────────────
MAGI_LAF_PROGRESS_CONFIRM_TTL_SEC=1800   # 確認碼 TTL（秒）；預設 30 分鐘

# ── T4 法學翻譯術語庫 ──────────────────────────────────────
MAGI_TRANSLATOR_LEGAL_MODE=auto          # auto | 1 | 0；auto=偵測到法律文字才啟用

# ── Feature Flag 管理（Round 1-5，2026-04-18）────────────────
MAGI_SINGLE_MACHINE=1                    # 1=單機模式；遠端 Melchior/Balthasar 探測預設跳過
MAGI_AVOID_DISTRIBUTED=1                 # 1=分散式推理需明確 opt-in 才會啟用

# 已開啟（zero-risk）
MAGI_PDF_OCR_CONSENSUS=1                 # Phase 2B 三引擎 OCR 共識（Round 1-A）
MAGI_BOOKMARKER_VISION_FALLBACK=1        # pdf-bookmarker Vision fallback（Round 3-B）
MAGI_ASSISTANT_MEMORY_LAYER1=1           # Layer 1 conversation_history SQLite（Round 4）
MAGI_VERIFIED_FACT_GATE=1               # Layer 3 verified_fact 升級閘門（Round 4）

# 保持關閉（需手動評估後再開）
MAGI_TRANSLATOR_APE=0                    # Apple Translation + LLM 後編輯；開前確認 Apple language pack 已下載
MAGI_USE_MARKITDOWN=0                    # MarkItDown 統一文件讀取；開前確認 markitdown[all] 已安裝
MAGI_CAPTURE_ASSISTANT_CHATLOG=0         # Layer 2 utterance log；開前確認使用者了解 privacy 影響

# ── Playwright 瀏覽器驅動引擎（2026-04-18 三模組遷移完成）────────
# 預設全部走 Playwright Chromium；設為 selenium 可強制退回 Selenium+ChromeDriver
MAGI_LAF_ENGINE=playwright               # 法扶 laf_automation_v2 引擎選擇
MAGI_FILE_REVIEW_WEB_ENGINE=playwright   # 閱卷 file_review_automation 引擎選擇
MAGI_TRANSCRIPT_WEB_ENGINE=playwright    # 筆錄 judicial_automation_v2 引擎選擇

# 安全紅線（永遠保持關閉）
# MAGI_ALLOW_CLOUD_MODELS=0             # 禁止打外部 API（隱私保護）
# MAGI_FILE_REVIEW_ALLOW_CONFIRM=0      # CLI 不得直接送出閱卷確認碼

# ─── NVIDIA NIM 雲端兜底（Plan A, 2026-04-19）───────────────────────────────
NVIDIA_NIM_ENABLE=0
NVIDIA_NIM_API_KEY=<<REPLACE_WITH_YOUR_nvapi-KEY>>
NVIDIA_NIM_MODEL=meta/llama-3.1-405b-instruct
NVIDIA_NIM_MODEL_FAST=meta/llama-3.3-70b-instruct
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_DAILY_BUDGET=500
NVIDIA_NIM_HEAVY_THRESHOLD_CHARS=20000
NVIDIA_NIM_REQUIRE_PII_SCRUB=1
NVIDIA_NIM_REQUIRE_OPTIN=1
NVIDIA_NIM_MAX_CONCURRENT=3

# ── Research Brief（2026-04-21，五命名空間多語文獻日報）────────
RESEARCH_BRIEF_DEDUPE_TTL_DAYS=60        # 已推播 URL 雜湊的保留天數
RESEARCH_BRIEF_MAX_ENTRIES_PER_NS=12     # 每命名空間單次摘要最多條目
RESEARCH_BRIEF_LOG=INFO                  # 模組 log level
MAGI_RESEARCH_BRIEF_TIMEOUT_SEC=120      # chat 觸發的 subprocess timeout

# ── Self-repair issue agenda（Phase 1，2026-04-21）────────
MAGI_ISSUE_TRACKER_ENABLE=0              # 預設關閉；開啟後寫 .runtime/issue_agenda.jsonl
MAGI_ISSUE_TRACKER_MARKDOWN=0            # legacy markdown mirror；預設關閉
MAGI_ISSUE_TRACKER_DEDUP_TTL_SEC=300     # 同 command+error 去重視窗
