# Melchior agent configuration (Windows)
# Copy this file to: C:\AI\MAGI\melchior.env  (same folder as melchior_agent_v2.py)
# Then start melchior_agent_v2.py (see start_melchior_v2.bat).

# Agent API (CASPER talks to this)
MELCHIOR_AGENT_PORT=5002

# Ollama (Engineer mode)
# Make sure Ollama is listening on localhost (default).
MELCHIOR_OLLAMA_URL=http://127.0.0.1:11434
MELCHIOR_DEFAULT_MODEL=qwen3:30b
MELCHIOR_STOP_OLLAMA_IN_DISTRIBUTED=1

# Distributed mode: llama.cpp llama-server provides OpenAI-compatible /v1 on this port
# CASPER will probe: http://<tailscale_ip>:8080/v1/models
MELCHIOR_LLAMA_V1_PORT=8080

# llama.cpp binary + model
MELCHIOR_LLAMA_SERVER_BIN=C:\AI\llama.cpp\bin\llama-server.exe
# Put your GGUF model here (example path). You must have this file locally.
MELCHIOR_LLAMA_MODEL_PATH=C:\AI\models\qwen3-30b-instruct.Q4_K_M.gguf

# RPC worker target (CASPER host running rpc-server).
# IMPORTANT: this must be CASPER Tailscale IP, not 0.0.0.0.
# Example: CASPER = 100.97.29.92
MELCHIOR_RPC_HOST=100.97.29.92
MELCHIOR_RPC_PORT=50052

# Performance tuning (adjust for your GPU/RAM)
# Context size
MELCHIOR_LLAMA_CTX=8192
# GPU offload layers (RTX 3060 12GB often works around 40-70 for 30B Q4; tune by OOM logs)
MELCHIOR_LLAMA_NGL=60
# Optional: set to 0 for auto
MELCHIOR_LLAMA_THREADS=0
MELCHIOR_LLAMA_BATCH=0

# Skills sync target folder on Windows
MELCHIOR_SKILLS_DIR=C:\AI\MAGI\skills
